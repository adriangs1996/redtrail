---
interface Props {
  title?: string;
  prompt?: string;
}

const { title = 'Terminal', prompt = '$ ' } = Astro.props;
---

<div class="terminal-frame">
  <div class="terminal-titlebar">
    <div class="terminal-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <span class="terminal-title">{title}</span>
    <div class="terminal-dots-spacer"></div>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal-frame {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    margin: 1.5rem 0;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Dark mode — Catppuccin Mocha */
  .terminal-frame {
    background: #1e1e2e;
    border: 1px solid #313244;
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #181825;
    border-bottom: 1px solid #313244;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .terminal-dots-spacer {
    width: 52px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #f38ba8; }
  .dot-yellow { background: #f9e2af; }
  .dot-green { background: #a6e3a1; }

  .terminal-title {
    flex: 1;
    text-align: center;
    color: #6c7086;
    font-size: 0.8rem;
    user-select: none;
  }

  .terminal-body {
    padding: 1rem;
    color: #cdd6f4;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal-body :global(pre) {
    margin: 0;
    padding: 0;
    background: transparent !important;
    border: none !important;
    color: inherit;
    font: inherit;
    overflow-x: auto;
  }

  .terminal-body :global(code) {
    background: transparent !important;
    color: inherit;
    font: inherit;
    padding: 0;
  }

  /* Light mode — Catppuccin Latte */
  :root[data-theme='light'] .terminal-frame {
    background: #e6e9ef;
    border-color: #ccd0da;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  :root[data-theme='light'] .terminal-titlebar {
    background: #dce0e8;
    border-bottom-color: #ccd0da;
  }

  :root[data-theme='light'] .dot-red { background: #d20f39; }
  :root[data-theme='light'] .dot-yellow { background: #df8e1d; }
  :root[data-theme='light'] .dot-green { background: #40a02b; }

  :root[data-theme='light'] .terminal-title {
    color: #9ca0b0;
  }

  :root[data-theme='light'] .terminal-body {
    color: #4c4f69;
  }
</style>
